# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/jalajogja

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:6202
NEXT_PUBLIC_APP_URL=http://localhost:6202

# ── MinIO — Object Storage (self-hosted) ──────────────────────────────────────
# Development: jalankan dengan `minio server ~/minio-data --console-address :9001`
# Console UI: http://localhost:9001
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
# URL publik untuk serve file (bisa beda di production jika pakai CDN/nginx proxy)
MINIO_PUBLIC_URL=http://localhost:9000
